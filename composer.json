{
    "name": "carvephp/carve",
    "description": "Find service boundaries in Laravel monoliths using static analysis + runtime tracing.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "microservices", "monolith", "refactoring", "service-boundaries", "static-analysis", "migration"],
    "homepage": "https://github.com/Muhammad-Waleed-Khalil/CarvePHP",
    "support": {
        "issues": "https://github.com/Muhammad-Waleed-Khalil/CarvePHP/issues",
        "source": "https://github.com/Muhammad-Waleed-Khalil/CarvePHP"
    },
    "authors": [
        {
            "name": "Muhammad Waleed Khalil",
            "email": "muhammadwaleedkhalil@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "Carve\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Carve\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Carve\\CarveServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
