{
  "$schema": "https://opencode.ai/opencode.json",
  "instructions": "AGENTS.md",
  "permissionDefaults": {
    "allow": [
      "read",
      "list",
      "glob",
      "grep",
      "bash",
      "git-status",
      "git-diff",
      "git-log"
    ],
    "ask": [
      "write",
      "edit",
      "search",
      "webfetch",
      "websearch",
      "composer",
      "php-artisan",
      "phpunit",
      "pint",
      "phpstan",
      "git-push",
      "git-commit"
    ],
    "deny": [
      "rm",
      "del",
      "rmdir",
      "remove-item",
      "git-reset-hard",
      "git-force-push"
    ]
  },
  "dangerMode": false,
  "allowOnlyOutputDirectories": [
    "carve-output"
  ]
}
